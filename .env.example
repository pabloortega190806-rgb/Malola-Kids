# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: URL de conexión a tu base de datos PostgreSQL en Neon
# Cópiala desde el panel de Neon (Dashboard -> Connection Details)
DATABASE_URL="postgresql://usuario:contraseña@ep-tu-endpoint.neon.tech/neondb?sslmode=require"

# BASE_URL_BLOB: URL base de tu almacenamiento en Vercel Blob
# Asegúrate de que termine con una barra (/)
BASE_URL_BLOB="https://tu-proyecto.public.blob.vercel-storage.com/"

# BLOB_READ_WRITE_TOKEN: Token de acceso para Vercel Blob
# Necesario para listar y buscar imágenes dinámicamente
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ADMIN_PASSWORD: Password for the store owner to log in and edit products
ADMIN_PASSWORD="MALOLAKIDS2026"

# ADMIN_TOKEN: Secret token used for admin API authentication
ADMIN_TOKEN="malola-admin-secret-token"

# STRIPE_SECRET_KEY: Stripe secret key for backend checkout session creation
STRIPE_SECRET_KEY="sk_test_..."

# VITE_STRIPE_PUBLISHABLE_KEY: Stripe publishable key for frontend checkout redirection
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
